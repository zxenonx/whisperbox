# ── Database ────────────────────────────────────────────────────────────────
# SQLite (local dev — no setup required)
DATABASE_URL=sqlite+aiosqlite:///./whisperbox.db

# Neon PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.neon.tech/whisperbox?sslmode=require

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

# Access token lifetime in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
